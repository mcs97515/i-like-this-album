generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  searches Search[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Album {
  id         String   @id @default(cuid())
  lastfmUrl  String?  @unique
  mbid       String?  @unique
  title      String
  artist     String
  artUrl     String?
  trackCount Int?
  tags       String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  searches              Search[]
  recommendationsAsSeed AlbumRecommendation[] @relation("SeedFor")
  recommendationsAs     AlbumRecommendation[] @relation("RecommendedAs")

  @@index([title, artist])
}

model Search {
  id          String   @id @default(cuid())
  userId      String
  query       String
  seedAlbumId String?
  createdAt   DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  seedAlbum Album? @relation(fields: [seedAlbumId], references: [id])

  @@index([userId, createdAt])
}

model AlbumRecommendation {
  id            String   @id @default(cuid())
  seedAlbumId   String
  recommendedId String
  position      Int
  score         Float?
  computedAt    DateTime @default(now())

  seedAlbum   Album @relation("SeedFor", fields: [seedAlbumId], references: [id], onDelete: Cascade)
  recommended Album @relation("RecommendedAs", fields: [recommendedId], references: [id], onDelete: Cascade)

  @@unique([seedAlbumId, recommendedId])
  @@index([seedAlbumId, position])
}
